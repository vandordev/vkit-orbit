# syntax=docker/dockerfile:1.11
FROM oven/bun:1.3.14-alpine AS base
WORKDIR /app
FROM base AS prune
COPY . .
RUN bunx turbo@2.10.4 prune web --docker
FROM base AS deps
COPY --from=prune /app/out/json/ ./
RUN bun install --frozen-lockfile --ignore-scripts
FROM base AS builder
COPY --from=deps /app/node_modules ./node_modules
COPY --from=prune /app/out/full/ ./
ARG DATABASE_URL=postgresql://boilerplate:boilerplate@db:5432/boilerplate
ENV DATABASE_URL=$DATABASE_URL NODE_ENV=production
RUN bun run --cwd packages/database db:generate
RUN bun run --cwd apps/web build
FROM oven/bun:1.3.14-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production PORT=4100 HOSTNAME=0.0.0.0
RUN addgroup -S app && adduser -S app -G app
COPY --from=builder --chown=app:app /app/node_modules ./node_modules
COPY --from=builder --chown=app:app /app/.output ./.output
COPY --from=builder --chown=app:app /app/packages/config ./packages/config
COPY --from=builder --chown=app:app /app/config ./config
COPY --from=builder --chown=app:app /app/package.json ./package.json
USER app
EXPOSE 4100
CMD ["bun", "run", "packages/config/src/run.ts", "--modules", "base,web,api,storage", "--", "bun", ".output/server/index.mjs"]
