# Required local database connection.
DATABASE_URL=postgresql://user:password@localhost:5432/boilerplate

# Optional runtime overrides.
NODE_ENV=development
LOG_LEVEL=debug
PORT=4100
OPENAPI_SERVER_URL=http://localhost:4100
VITE_REALTIME_URL=http://localhost:4102
REALTIME_CORS_ORIGIN=http://localhost:4100
WORKER_NOTIFICATION_URL=http://localhost:4100/api/internal/worker-events
WORKER_NOTIFICATION_API_KEY=replace-with-a-local-secret
REALTIME_INTERNAL_URL=http://localhost:4102
REALTIME_PUBLISH_API_KEY=replace-with-a-local-secret
ENABLE_EXAMPLE_SCHEDULE=false
EXAMPLE_SCHEDULE_INTERVAL_MS=300000
REALTIME_PORT=4102

# Optional OpenAPI protection.
OPENAPI_BASIC_AUTH_USERNAME=
OPENAPI_BASIC_AUTH_PASSWORD=

# Required when selecting the realtime module.
REALTIME_TICKET_SECRET=replace-with-a-local-secret

# Optional private S3/MinIO object storage.
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_ROOT_PREFIX=uploads
